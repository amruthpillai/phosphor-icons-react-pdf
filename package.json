{
	"name": "phosphor-icons-react-pdf",
	"version": "0.1.0",
	"description": "@react-pdf/renderer-compatible Phosphor Icons components for browser and Node.js PDF generation.",
	"type": "module",
	"license": "MIT",
	"author": {
		"name": "Amruth Pillai",
		"email": "im.amruth@gmail.com",
		"url": "https://amruthpillai.com"
	},
	"homepage": "https://github.com/amruthpillai/phosphor-icons-react-pdf#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/amruthpillai/phosphor-icons-react-pdf.git"
	},
	"bugs": {
		"url": "https://github.com/amruthpillai/phosphor-icons-react-pdf/issues"
	},
	"keywords": [
		"phosphor",
		"phosphor-icons",
		"react-pdf",
		"@react-pdf/renderer",
		"pdf",
		"icons",
		"svg",
		"react"
	],
	"sideEffects": false,
	"files": [
		"dist"
	],
	"main": "./dist/index.cjs.js",
	"module": "./dist/index.es.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.es.js",
			"require": "./dist/index.cjs.js"
		},
		"./icons": {
			"types": "./dist/icons/index.d.ts",
			"import": "./dist/icons/index.es.js",
			"require": "./dist/icons/index.cjs.js"
		},
		"./icons/*": {
			"types": "./dist/icons/*.d.ts",
			"import": "./dist/icons/*.es.js",
			"require": "./dist/icons/*.cjs.js"
		},
		"./thin": {
			"types": "./dist/thin/index.d.ts",
			"import": "./dist/thin/index.es.js",
			"require": "./dist/thin/index.cjs.js"
		},
		"./thin/*": {
			"types": "./dist/thin/*.d.ts",
			"import": "./dist/thin/*.es.js",
			"require": "./dist/thin/*.cjs.js"
		},
		"./light": {
			"types": "./dist/light/index.d.ts",
			"import": "./dist/light/index.es.js",
			"require": "./dist/light/index.cjs.js"
		},
		"./light/*": {
			"types": "./dist/light/*.d.ts",
			"import": "./dist/light/*.es.js",
			"require": "./dist/light/*.cjs.js"
		},
		"./regular": {
			"types": "./dist/regular/index.d.ts",
			"import": "./dist/regular/index.es.js",
			"require": "./dist/regular/index.cjs.js"
		},
		"./regular/*": {
			"types": "./dist/regular/*.d.ts",
			"import": "./dist/regular/*.es.js",
			"require": "./dist/regular/*.cjs.js"
		},
		"./bold": {
			"types": "./dist/bold/index.d.ts",
			"import": "./dist/bold/index.es.js",
			"require": "./dist/bold/index.cjs.js"
		},
		"./bold/*": {
			"types": "./dist/bold/*.d.ts",
			"import": "./dist/bold/*.es.js",
			"require": "./dist/bold/*.cjs.js"
		},
		"./fill": {
			"types": "./dist/fill/index.d.ts",
			"import": "./dist/fill/index.es.js",
			"require": "./dist/fill/index.cjs.js"
		},
		"./fill/*": {
			"types": "./dist/fill/*.d.ts",
			"import": "./dist/fill/*.es.js",
			"require": "./dist/fill/*.cjs.js"
		},
		"./duotone": {
			"types": "./dist/duotone/index.d.ts",
			"import": "./dist/duotone/index.es.js",
			"require": "./dist/duotone/index.cjs.js"
		},
		"./duotone/*": {
			"types": "./dist/duotone/*.d.ts",
			"import": "./dist/duotone/*.es.js",
			"require": "./dist/duotone/*.cjs.js"
		}
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"generate": "tsx scripts/generate-icons.ts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"@react-pdf/renderer": ">=4.0.0",
		"react": ">=18.0.0 || >=19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@phosphor-icons/core": "^2.1.1",
		"@react-pdf/renderer": "^4.5.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "4.1.5",
		"react": "^19.2.5",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vite-plugin-dts": "^5.0.0",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
